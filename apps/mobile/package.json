{
  "name": "@parking-ticket-pal/mobile",
  "main": "expo-router/entry",
  "version": "1.0.3",
  "expo": {
    "autolinking": {
      "nativeModulesDir": "./modules",
      "exclude": [
        "@expo/dom-webview"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "document-detector",
          "react-native-streetview",
          "vision-camera-resize-plugin",
          "expo-modules-jsi",
          "@react-native-ml-kit/text-recognition"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "scripts": {
    "clean": "git clean -xdf .expo node_modules",
    "start": "expo start",
    "dev": "expo start --ios",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "ios": "expo run:ios --no-build-cache",
    "android": "expo run:android --no-build-cache",
    "build:ios": "pnpm prebuild:ios && pnpm ios",
    "build:android": "pnpm prebuild:android && pnpm android",
    "build": "expo export",
    "eas:build:local": "eas build --profile development --local",
    "eas:build:local:android": "eas build --platform android --profile preview --local",
    "eas:build:local:ios": "eas build --platform ios --profile preview --local",
    "eas:build:development": "eas build --profile development",
    "eas:build:development:android": "eas build --platform android --profile development",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:preview:ios": "eas build --profile preview --platform ios",
    "eas:build:preview:android": "eas build --profile preview --platform android",
    "eas:build:preview:ios:local": "eas build --profile preview --platform ios --local",
    "eas:build:preview:android:local": "eas build --profile preview --platform android --local",
    "eas:build:production": "eas build --profile production",
    "eas:release:ios": "eas build --profile production --platform ios --local --auto-submit",
    "eas:release:android": "eas build --profile production --platform android --local --auto-submit",
    "eas:submit:production": "eas submit --profile production",
    "release": "node scripts/release.mjs",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "check-types": "tsc --noEmit",
    "env:pull": "eas env:pull --environment development",
    "postinstall": "npx install-skia"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.1",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^6.7.1",
    "@fortawesome/pro-light-svg-icons": "^6.7.1",
    "@fortawesome/pro-regular-svg-icons": "^6.7.1",
    "@fortawesome/pro-solid-svg-icons": "^6.7.1",
    "@fortawesome/react-native-fontawesome": "^0.3.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@invertase/react-native-apple-authentication": "^2.4.1",
    "@parking-ticket-pal/constants": "workspace:*",
    "@parking-ticket-pal/types": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-google-signin/google-signin": "^16.0.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-native-picker/picker": "^2.11.1",
    "@sentry/react-native": "^7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "^2.6.4",
    "@tanstack/react-form": "^1.23.8",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "expo": "56.0.8",
    "expo-application": "~56.0.3",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.16",
    "expo-checkbox": "~56.0.1",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-drawpad": "^0.3.1",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-picker": "~56.0.15",
    "expo-insights": "~56.0.15",
    "expo-linking": "~56.0.13",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.15",
    "expo-router": "56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-tracking-transparency": "^56.0.5",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "mime": "^4.0.4",
    "nativewind": "5.0.0-preview.2",
    "posthog-react-native": "^4.9.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-awesome-gallery": "^0.4.3",
    "react-native-css": "^3.0.4",
    "react-native-fast-opencv": "^0.4.7",
    "react-native-fbsdk-next": "^13.4.1",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-google-mobile-ads": "^15.8.0",
    "react-native-keyboard-controller": "^1.21.6",
    "react-native-maps": "1.27.2",
    "react-native-purchases": "^9.5.4",
    "react-native-reanimated": "~4.3.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-streetview": "^0.4.4",
    "react-native-svg": "15.15.4",
    "react-native-vision-camera": "^4.7.1",
    "react-native-web": "~0.21.1",
    "react-native-worklets": "^0.8.3",
    "react-native-worklets-core": "^1.3.3",
    "sonner-native": "^0.23.1",
    "tailwind-merge": "^3.0.1",
    "vision-camera-resize-plugin": "^3.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^18.3.0",
    "eslint-config-expo": "~56.0.4",
    "expo-mcp": "~0.2.1",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "mime-types": "^2.1.35",
    "postcss": "^8",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react-test-renderer": "18.3.1",
    "tailwindcss": "^4",
    "typescript": "~6.0.3"
  },
  "private": true
}
