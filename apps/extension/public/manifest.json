{
  "manifest_version": 3,
  "name": "Parking Ticket Pal",
  "version": "1.0.0",
  "description": "Import parking tickets from council portals into Parking Ticket Pal.",
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "host_permissions": [
    "https://pcnevidence.lewisham.gov.uk/*",
    "https://horizonparkingportal.co.uk/*",
    "https://*.westminster.gov.uk/*",
    "https://www.parkingticketpal.com/*",
    "https://parkingticketpal.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/logo.png"],
      "matches": [
        "https://pcnevidence.lewisham.gov.uk/*",
        "https://horizonparkingportal.co.uk/*",
        "https://*.westminster.gov.uk/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://pcnevidence.lewisham.gov.uk/*",
        "https://horizonparkingportal.co.uk/*",
        "https://*.westminster.gov.uk/*"
      ],
      "js": ["content-issuer.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.parkingticketpal.com/auth/extension/*",
        "https://parkingticketpal.com/auth/extension/*"
      ],
      "js": ["content-auth-relay.js"],
      "run_at": "document_idle"
    }
  ]
}
