# .easignore — controls what gets uploaded to the EAS cloud build runner.
# Same syntax as .gitignore. When .easignore exists, EAS uses ONLY this file
# and IGNORES .gitignore entirely, so this file must be a complete superset
# of .gitignore plus any EAS-specific exclusions.
#
# Why this exists: this monorepo has several workspaces (apps/web,
# apps/extension, packages/db) that the mobile app does NOT depend on.
# Uploading them anyway makes the EAS runner run `pnpm install` against
# their dependencies too, including native modules like `sharp` (used by
# the web app for image optimisation). sharp's postinstall fails on the
# EAS Linux runner because no prebuild matches its Node version → the
# whole install fails before iOS native build even starts.
#
# Mobile's actual workspace deps are:
#   - @parking-ticket-pal/constants  (packages/constants)
#   - @parking-ticket-pal/types      (packages/types)
# Everything else can be excluded.

# === Mirror of .gitignore ===
# (Kept in sync manually; if you change .gitignore, mirror the relevant
# bits here too.)

node_modules
.pnp
.pnp.js

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage
playwright-report/
test-results/
blob-report/

# Turbo
.turbo

# Vercel
.vercel

# Build outputs
.next/
out/
build
dist

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem

# Mobile builds — these can pile up to multi-GB and tank the EAS upload
*.apk
*.ipa
*.aab

# Native iOS/Android build artifacts (regenerated by expo prebuild)
ios/build/
ios/Pods/
*.xcworkspace
*.xcuserdata/
android/build/
android/app/build/
android/.gradle/
apps/mobile/ios/
apps/mobile/android/
apps/mobile/.expo/

# Large dev data files
packages/db/data/tribunal-seed/*.json
scripts/fixtures/images/
scripts/dry-run-results.json

# Editor + tooling junk
.vscode/
.cursor/
.claude/

# === EAS-only exclusions ===
# Other workspaces — mobile doesn't import any code from these. Excluding
# them prevents pnpm from trying to install their deps (e.g. sharp in web).
apps/web/
apps/extension/
packages/db/
