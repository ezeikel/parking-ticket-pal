{
  "name": "parking-ticket-pal",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "rm -rf apps/*/node_modules packages/*/node_modules",
    "clean:deep": "rm -rf apps/*/node_modules packages/*/node_modules pnpm-lock.yaml && pnpm install",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.6.2",
    "turbo": "^2.8.11",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@shopify/react-native-skia",
      "@sentry/cli",
      "core-js",
      "esbuild",
      "prisma",
      "@prisma/engines",
      "protobufjs",
      "unrs-resolver"
    ]
  },
  "resolutions": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@types/react": "^19.2.10",
    "lightningcss": "1.30.1"
  }
}
